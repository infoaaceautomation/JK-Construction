{
  "name": "jk-construction-revamp",
  "version": "1.0.0",
  "description": "Revamped 3D website for JK Construction (Jabalpur)",
  "scripts": {
    "install-all": "npm install && npm install --prefix server && npm install --prefix client --legacy-peer-deps",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "start": "node server/server.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
